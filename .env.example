# ===========================================
# Vital RP Photo Contest - Environment Config
# ===========================================
# Copy this file to .env and fill in your values.
# These same variables should be set in your Vercel dashboard.

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Discord OAuth
VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback
# Server-side only (Vercel env vars, NOT prefixed with VITE_)
DISCORD_CLIENT_SECRET=

# FiveManage API (Phase 2)
VITE_FIVEMANAGE_API_KEY=

# Firebase Admin SDK (Server-side only for Vercel functions)
FIREBASE_SERVICE_ACCOUNT_KEY=
